// Program to find maximum of two numbers.
#include<iostream>
using namespace std;
int maxx(int num1, int num2){
    if (num1>num2){
        return num1;
    }
    else if (num1<num2) {
        return num2;
    }
    else {
        cout<<"Equal";
        return 0;
    }

}
int main(){
    int num1, num2;
    cin>> num1 >> num2;
    int maximum = maxx(num1,num2);
    cout<< maximum;
    return 0 ;
}
